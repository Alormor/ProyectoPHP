# Configuración de la Aplicación
APP_NAME="Tienda Online"
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE="Europe/Madrid"

# Base URL
BASE_URL=http://localhost/ProyectoPHP

# Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=tienda
DB_PORT=3306
DB_CHARSET=utf8mb4

# Configuración de Sesión
SESSION_NAME=tienda_session
SESSION_LIFETIME=3600

# Configuración SMTP de Mailtrap
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_SECURE=tls
MAILTRAP_USER=afd84be52a21e1
MAILTRAP_PASS=98034000f4ede4
MAILTRAP_FROM=no-reply@cubos3.com
MAILTRAP_FROM_NAME="Mi Proyecto PHP"

# Configuración SMTP para Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=tu-cuenta@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
SMTP_FROM=tu-cuenta@gmail.com
SMTP_FROM_NAME="Mi Proyecto PHP"

# URL Base para el enlace de confirmación
APP_URL=http://localhost/ProyectoPHP

# PAYPAL
PAYPAL_CLIENT_ID=ClientIDExample1234567890
PAYPAL_SECRET=SecretExample1234567890
PAYPAL_MODE=sandbox
